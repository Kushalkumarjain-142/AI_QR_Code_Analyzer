# --- AI_QR_ANALYZER CUSTOM ---
# Protect your API keys and credentials
secret.toml
secrets.toml
.env
*.env
.secrets

# --- PYTHON ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
.venv
venv/
ENV/
env/

# --- STREAMLIT ---
# Ignore everything in .streamlit except configuration
.streamlit/*
! .streamlit/config.toml
! .streamlit/credentials.toml

# --- DOCKER ---
# If you generate local data volumes or logs
.docker/
*.log


